{
  "name": "@choigawoon/msw-vfs-cli",
  "version": "0.5.1",
  "description": "Fast, cross-platform CLI for reading and editing MapleStory Worlds .map/.ui/.gamelogic/.model assets without the editor or MCP.",
  "main": "dist/index.js",
  "bin": {
    "msw-vfs": "bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "win32",
    "linux"
  ],
  "files": [
    "bin/",
    "dist/",
    "assets/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/choigawoon/msw-vfs-cli.git"
  },
  "keywords": [
    "msw",
    "maplestory-worlds",
    "vfs",
    "cli",
    "map",
    "ui",
    "model",
    "game-assets"
  ],
  "author": "choigawoon",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/choigawoon/msw-vfs-cli/issues"
  },
  "homepage": "https://github.com/choigawoon/msw-vfs-cli#readme",
  "dependencies": {
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
